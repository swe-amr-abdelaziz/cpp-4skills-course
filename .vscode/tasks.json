{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: g++ build one active file",
      "command": "/usr/bin/g++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-pedantic-errors",
        "${file}",
        "-std=c++17",
        "-Wall",
        "-Weffc++",
        "-Wextra",
        "-pedantic",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task to build single .cpp file"
    },
    {
      "type": "cppbuild",
      "label": "C/C++: g++ build multiple files",
      "command": "/usr/bin/g++",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "-pedantic-errors",
        "${fileDirname}/*.cpp",
        "${fileDirname}/*.h",
        "${fileDirname}/src/*.cpp",
        "${fileDirname}/include/*.h",
        "-std=c++17",
        "-Wall",
        "-Weffc++",
        "-Wextra",
        "-pedantic",
        "-o",
        "${fileDirname}/${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Task to build multiple .cpp and .h files"
    }
  ],
  "version": "2.0.0"
}
